# ==========================================
# DFree Novelish — Environment Configuration
# ==========================================

# Server port
PORT=3000

# ==========================================
# GROQ API KEY — Powers the AI Chatbot
# Get yours: https://console.groq.com
# ==========================================


# ==========================================
# EMAIL (SMTP) — Contact form notifications
# Gmail: enable 2FA > App Passwords > Generate 16-char password
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Admin email — receives all form submissions
NOTIFY_EMAIL=info@dfreenovelish.com
